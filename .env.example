# Azure Portal → App Registrations → your app
MICROSOFT_APP_ID=your-app-id                # Application (client) ID
MICROSOFT_APP_PASSWORD=your-app-password    # Certificates & secrets → Client Secret Value
MICROSOFT_APP_TENANT_ID=your-tenant-id      # Directory (tenant) ID

# Server
PORT=3978

# Dev tunnel (persistent ID)
DEVTUNNEL_ID=your-tunnel-id

# Claude Code working directory (required, must exist)
CLAUDE_WORK_DIR=~/Work

# Auto-generated by setup (do not edit)
TEAMS_APP_ID=auto-generated-uuid              # Unique Teams app identifier
