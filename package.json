{
  "name": "claude-code-teams-bot",
  "version": "1.0.0",
  "description": "Microsoft Teams bot that bridges to Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "teams-bot": "./scripts/ctl.sh"
  },
  "scripts": {
    "dev": "concurrently -k -n bot,tunnel -c blue,green \"tsx watch src/index.ts\" \"node scripts/tunnel.mjs\"",
    "dev:local": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:@anthropic-ai/claude-agent-sdk --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "node scripts/package-manifest.mjs",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.64",
    "botbuilder": "^4.23.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
